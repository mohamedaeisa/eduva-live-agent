# Streamlined Dockerfile for FAST deployments
# This assumes you have already run 'npm run build' locally.

FROM node:20-slim
WORKDIR /app

# Only install production dependencies
COPY package*.json ./
RUN npm install --omit=dev --legacy-peer-deps && npm install tsx

# Copy the locally built frontend
COPY dist ./dist

# Copy the server and required source files
COPY server.js ./server.js
COPY .env.local* ./

# Environment configuration
ENV NODE_ENV=production
ENV PORT=8080
EXPOSE 8080

# Start server using tsx
CMD ["npx", "tsx", "server.js"]
